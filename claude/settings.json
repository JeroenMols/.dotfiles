{
  "permissions": {
    "allow": [
      "Bash(tmux set-window-option:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(bin/parallel-rspec:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git push:*)",
      "Bash(git filter-branch:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run format:*)",
      "mcp__plaid-mcp-default__get_buildkite_failures",
      "mcp__plaid-mcp-default__query_plogger_logs",
      "mcp__sentry__get_issue_details",
      "mcp__sentry__search_issue_events",
      "mcp__sentry__search_events",
      "mcp__sentry__get_event_attachment",
      "mcp__sentry__get_trace_details"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git_root=$(git rev-parse --show-toplevel 2>/dev/null); if [ -n \"$git_root\" ]; then prefix=$(git rev-parse --show-prefix 2>/dev/null); if [ -z \"$prefix\" ]; then dir=$(basename \"$git_root\"); else dir=${prefix%/}; fi; else dir=$(basename \"$PWD\"); fi; tmux rename-window -t \"$TMUX_PANE\" \"Claude [$dir]\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "BASE=$(tmux display-message -p -t \"$TMUX_PANE\" '#W' | sed 's/^⏳//; s/^[✓?] //'); tmux rename-window -t \"$TMUX_PANE\" \"⏳$BASE\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "BASE=$(tmux display-message -p -t \"$TMUX_PANE\" '#W' | sed 's/^⏳//; s/^[✓?] //'); tmux rename-window -t \"$TMUX_PANE\" \"✓ $BASE\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux rename-window -t \"$TMUX_PANE\" zsh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CURRENT=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); case \"$CURRENT\" in ✓*) ;; *) BASE=$(echo \"$CURRENT\" | sed 's/^⏳//; s/^[✓?] //'); tmux rename-window -t \"$TMUX_PANE\" \"? $BASE\" ;; esac"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "plaid-deployment-monitor@plaid-plugins": true,
    "example-skills@anthropic-agent-skills": true,
    "plaid-idv-toolkit@plaid-plugins": true
  },
  "extraKnownMarketplaces": {
    "plaid-plugins": {
      "source": {
        "source": "git",
        "url": "git@github.plaid.com:plaid/agent-tools.git"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754637305959
  }
}
